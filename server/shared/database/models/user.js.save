'use strict';
const { Model } = require('sequelize');  // убрал DataTypes отсюда

module.exports = (sequelize, DataTypes) => {
  class User extends Model {
    static associate(models) {
      // define association here
    }
  }
  
  User.init({
    id: {
      type: DataTypes.INTEGER,
      autoIncrement: true,
      primaryKey: true,
    },
    userName: {
      type: DataTypes.STRING,
      allowNull: true,
    },
    email: {
      type: DataTypes.STRING,
      unique: true,
      allowNull: false,
    },
    hashpass: {
      type: DataTypes.STRING,
      allowNull: false,
    },
  }, {    sequelize,
    modelName: 'User',
    tableName: 'Users',
    timestamps: true,
  });
  
  return User;
};
